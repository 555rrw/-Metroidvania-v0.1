[sub_resource type="GDScript" id="GDScript_barrier"]
script/source = "extends StaticBody2D

@export var event_name: String = \"boss_defeated\"
@export var fade_seconds: float = 0.4

func _ready() -> void:
	_check_boss()

func _check_boss() -> void:
	var game = get_tree().get_first_node_in_group(&\"game\")
	if game and event_name in game.events:
		set_deferred(\"collision_layer\", 0)
		set_deferred(\"collision_mask\", 0)
		var tween = create_tween()
		tween.tween_property(self, \"modulate:a\", 0.0, fade_seconds)
		tween.tween_callback(queue_free)
	else:
		get_tree().create_timer(0.5).timeout.connect(_check_boss)
"

